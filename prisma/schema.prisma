// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  password     String    @db.VarChar(255)
  role         Role      @default(USER)
  provider     Provider  @default(CREDENTIALS)
  isVerified   Boolean   @default(false) @map("is_verified")
  fullName     String?   @map("full_name") @db.VarChar(255)
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  gender       Gender?
  education    String?   @db.VarChar(255)
  address      String?   @db.Text
  city         String?   @db.VarChar(100)
  profilePhoto String?   @map("profile_photo") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  company      Company?
  cvs          CV[]
  applications Application[]
  refreshToken RefreshToken?

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.Text
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiredAt DateTime @map("expired_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("refresh_tokens")
}

model Company {
  id          Int      @id @default(autoincrement())
  adminId     Int      @unique @map("admin_id")
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  companyName String   @map("company_name") @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  description String?  @db.Text
  address     String?  @db.Text
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  jobs Job[]

  @@map("companies")
}

model Job {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String    @db.VarChar(255)
  description String    @db.Text
  banner      String?   @db.Text
  salary      Decimal?  @db.Decimal(12, 2)
  city        String    @db.VarChar(100)
  deadline    DateTime  @db.Timestamptz(6)
  status      JobStatus @default(DRAFT)
  preTest     Boolean   @default(false) @map("pre_test")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  applications     Application[]
  preSelectionTest PreSelectionTest?

  @@map("jobs")
}

model PreSelectionTest {
  id    Int    @id @default(autoincrement())
  jobId Int    @unique @map("job_id")
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title String @db.VarChar(255)

  questions   TestQuestion[]
  testResults TestResult[]

  @@map("pre_selection_tests")
}

model TestQuestion {
  id            Int              @id @default(autoincrement())
  testId        Int              @map("test_id")
  test          PreSelectionTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionText  String           @map("question_text") @db.Text
  correctAnswer String           @map("correct_answer") @db.VarChar(255)

  options TestOption[]

  @@map("test_questions")
}

model TestOption {
  id         Int          @id @default(autoincrement())
  questionId Int          @map("question_id")
  question   TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionText String       @map("option_text") @db.VarChar(255)
  isCorrect  Boolean      @default(false) @map("is_correct")

  @@map("test_options")
}

model CV {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvName    String   @map("cv_name") @db.VarChar(255)
  fileUrl   String   @map("file_url") @db.Text
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  applications Application[]

  @@map("cvs")
}

model Application {
  id              Int               @id @default(autoincrement())
  userId          Int               @map("user_id")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId           Int               @map("job_id")
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cvId            Int               @map("cv_id")
  cv              CV                @relation(fields: [cvId], references: [id])
  expectedSalary  Decimal?          @map("expected_salary") @db.Decimal(12, 2)
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?           @map("rejection_reason") @db.Text
  appliedAt       DateTime          @default(now()) @map("applied_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  interview  Interview?
  testResult TestResult?

  @@map("applications")
}

model Interview {
  id            Int         @id @default(autoincrement())
  applicationId Int         @unique @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewDate DateTime    @map("interview_date") @db.Timestamptz(6)
  locationLink  String?     @map("location_link") @db.Text
  reminderSent  Boolean     @default(false) @map("reminder_sent")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("interviews")
}

model TestResult {
  id                 Int              @id @default(autoincrement())
  preSelectionTestId Int              @map("pre_selection_test_id")
  preSelectionTest   PreSelectionTest @relation(fields: [preSelectionTestId], references: [id], onDelete: Cascade)
  applicationId      Int              @unique @map("application_id")
  application        Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  score              Decimal          @db.Decimal(5, 2)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("test_results")
}

enum Role {
  USER
  ADMIN
}

enum Provider {
  CREDENTIALS
  GOOGLE
}

enum Gender {
  MALE
  FEMALE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  PROCESSED
  INTERVIEW
  ACCEPTED
  REJECTED
}
